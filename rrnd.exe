#include <windows.h>

int main() {

    while (1) {

        HDC hdc = GetDC(0);

        int h = GetSystemMetrics(0);
        int w = GetSystemMetrics(1);

        BitBlt(hdc, rand() % 666, rand() % 666, h, w, hdc, rand() % 666, rand() % 666, NOTSRCERASE);

        ReleaseDC(0, hdc);
        
    }
}
    #include <windows.h>
#include <mmsystem.h>
#pragma comment(lib, "winmm.lib")

int main() {
    HDC hdc = GetDC(NULL);
    int screenWidth = GetSystemMetrics(SM_CXSCREEN);
    int screenHeight = GetSystemMetrics(SM_CYSCREEN);

    PlaySound(TEXT("html5bytebeat(1).wav"), NULL, SND_FILENAME | SND_ASYNC | SND_LOOP);

    while (true) {
        BitBlt(hdc, 0, 10, screenWidth, screenHeight, hdc, 0, 0, SRCCOPY);
        Sleep(10);
    }

    ReleaseDC(NULL, hdc);
    return 0;
}